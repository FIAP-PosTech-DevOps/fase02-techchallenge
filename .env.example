# NOTA DE ESTUDO da FASE:
# .env local + .gitignore, já que a AWS Academy dá credenciais temporárias (AWS_SESSION_TOKEN) que expiram em poucas horas de qualquer forma. 
# Cada membro do grupo mantém seu próprio .env local, nunca comitado.
# No Kubernetes (Etapa 4 do desafio), as credenciais não vão mais em .env — vão em Secrets do K8s, 
# que o próprio enunciado já pede ("Secrets: para injetar com segurança todas as senhas"). 
# Secret do K8s por padrão é só base64 (não é criptografia forte), então em produção de verdade se usa algo como AWS Secrets Manager ou Sealed Secrets — 
# mas este desafio, Secret nativo do K8s tá de boas.
# Em ambiente corporativo real (tipo o seu dia a dia lá na empresa), aí AWS Secrets Manager, KMS.

# IMPORT|ANTE: se em algum momento você já commitou um .env com credencial real por engano antes de eu revisar isso 
# simplesmente apagar o arquivo depois não resolve — ele continua no histórico do Git. 
# Nesse cenário aí sim precisaria reescrever histórico (git filter-repo ou similar) ou, mais simples, 
# revogar a credencial na AWS e gerar uma nova. Como o exemple é fake total e o .gitignore já está certo!
# 


# Copie este arquivo para ".env" na raiz do projeto e preencha com suas credenciais.
# O docker-compose.yml lê essas variáveis automaticamente.

# --- auth-service ---
MASTER_KEY=admin-secreto-123

# --- evaluation-service (chave gerada pelo auth-service, ver README) ---
SERVICE_API_KEY=

# --- Credenciais AWS Academy (obrigatório para analytics-service; opcional para evaluation-service) ---
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

# --- Fila SQS real da AWS (não há SQS local no requisito da Fase 2) ---
AWS_SQS_URL=https://sqs.us-east-1.amazonaws.com/SEU_ACCOUNT_ID/sua-fila

# --- Tabela DynamoDB (local ou real, dependendo se você aplicar o patch de endpoint_url) ---
AWS_DYNAMODB_TABLE=ToggleMasterAnalytics
